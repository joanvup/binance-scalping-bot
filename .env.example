# MODOS: TESTNET, DRY_RUN, LIVE
EXECUTION_MODE=TESTNET
TIMESYNCDATE=360

# CREDENCIALES LIVE (Reales) - Se usan para LIVE y DRY_RUN (en Dry-run solo lectura)
BINANCE_API_KEY_LIVE=myapikey de prueba 
BINANCE_API_SECRET_LIVE=mysecretkey de prueba

# CREDENCIALES TESTNET - Se obtienen en testnet.binancefuture.com
BINANCE_API_KEY_TESTNET=myapikey de prueba 
BINANCE_API_SECRET_TESTNET=mysecretkey de prueba

# CONFIGURACIÓN DE TRADING (Valores por defecto del dashboard)
SYMBOL=HBARUSDT
TIMEFRAME=5m
LEVERAGE=10
TAKE_PROFIT_PCT=1.0
DCA_DROP_PCT=2.0
MAX_RISK_PCT=10.0
# Margen inicial en USDT por cada operación (primer disparo)
INITIAL_USDT_MARGIN=50.0
INITIAL_BALANCE_DRYRUN=300.0